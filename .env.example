# Optional. Defaults to http://localhost:4000.
# When set, /api/* requests are proxied here from the Vite dev server.
VITE_BACKEND_ORIGIN=http://localhost:4000

# Password gate (optional): leave empty to disable. When set, also set VITE_APP_GATE_SESSION_SECRET.
# VITE_APP_GATE_PASSWORD=

# Encrypts persisted gate unlock in localStorage (must be set whenever the password is set for production).
# Use a long random string (not the same as the gate password).
# VITE_APP_GATE_SESSION_SECRET=
